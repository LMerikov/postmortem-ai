# Backend Configuration Template
# ⚠️ IMPORTANT: Copy this file to .env and fill with your actual values
# ⚠️ NEVER commit .env with real API keys to version control

# ═══════════════════════════════════════════════════════════════════════════
# LLM PROVIDERS (at least one required)
# ═══════════════════════════════════════════════════════════════════════════

# Primary Provider: Groq (fastest, ~3s, cheapest)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Fallback Provider: Anthropic Claude (reliable, ~25s)
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# Optional: Google Gemini (alternative/fast)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# ═══════════════════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════════════════
SECRET_KEY=generate-a-random-32-char-secret-key-for-sessions
FLASK_ENV=production
DEBUG=False
BIND_HOST=127.0.0.1

# ═══════════════════════════════════════════════════════════════════════════
# FRONTEND & CORS
# ═══════════════════════════════════════════════════════════════════════════
CORS_ORIGINS=https://postmortem-ai.xyz,https://app.postmortem-ai.xyz

# Development:
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════════════════
DATABASE_PATH=/app/data/postmortems.db
# Optional: PostgreSQL for cache (production)
# DATABASE_URL=postgresql://user:password@postgres-service:5432/postmortem_db

# ═══════════════════════════════════════════════════════════════════════════
# CACHE & PERFORMANCE
# ═══════════════════════════════════════════════════════════════════════════
CACHE_TTL_HOURS=24
MAX_LOG_TOKENS=4000
